# ── LLM APIs ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here          # https://console.groq.com
GOOGLE_API_KEY=your_google_api_key_here      # optional

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=your_hf_token_here                  # https://huggingface.co/settings/tokens

# ── LangSmith (optional tracing) ─────────────────────────────────────────────
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=Sift

# ── Local Database (Docker Compose) ──────────────────────────────────────────
DATABASE_URL=postgresql://veridai:veridai123@localhost:5432/veridai

# ── Local Redis (Docker Compose) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Evidence APIs ─────────────────────────────────────────────────────────────
GUARDIAN_API_KEY=your_guardian_api_key_here  # https://open-platform.theguardian.com/access/

# ── Cloud deployment (optional) ───────────────────────────────────────────────
NEON_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
UPSTASH_REDIS_URL=rediss://default:pass@host:port
